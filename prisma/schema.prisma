generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── AUTH & TEAM ─────────────────────────────────────────

model User {
  id               String    @id @default(uuid())
  name             String
  email            String    @unique
  phone            String?
  password         String
  role             String    @default("admin")
  isActive         Boolean   @default(true)
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  outOfOffice      Boolean   @default(false)
  outOfOfficeUntil DateTime?
  backupUserId     String?
  backupUser       User?     @relation("UserBackup", fields: [backupUserId], references: [id], onDelete: SetNull)
  backupFor        User[]    @relation("UserBackup")

  activities      Activity[]
  assignedTickets Ticket[]
  auditLogs       AuditLog[]
  invitesSent     TeamInvite[]
  ownedDeals      Deal[]
  ownedContacts   Contact[]
  sentEmails      EmailMessage[]
  sentWhatsApp    WhatsAppMessage[]
  emailAccounts   EmailAccount[]
  salesTargets    SalesTarget[]
  notifications   Notification[]
  tasks           Task[]
  apiKeys         ApiKey[]
  handoffRequests       LeadHandoffRequest[] @relation("HandoffRequester")
  handoffReviews        LeadHandoffRequest[] @relation("HandoffReviewer")
}

// ─── EMAIL ACCOUNTS (per-user mailbox connections) ───────

model EmailAccount {
  id            String    @id @default(uuid())
  provider      String    @default("microsoft") // microsoft | google | smtp
  emailAddress  String
  displayName   String?
  accessToken   String?   // encrypted at rest in future; plain for now
  refreshToken  String?
  expiresAt     DateTime?
  scope         String?
  isDefault     Boolean   @default(true)
  isActive      Boolean   @default(true)
  lastSyncedAt  DateTime?
  lastError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, emailAddress])
}

model TeamInvite {
  id        String   @id @default(uuid())
  email     String
  role      String   @default("agent")
  status    String   @default("pending")
  token     String   @unique @default(uuid())
  createdAt DateTime @default(now())

  invitedById String
  invitedBy   User   @relation(fields: [invitedById], references: [id], onDelete: Cascade)
}

// ─── CRM ─────────────────────────────────────────────────

model Contact {
  id               String    @id @default(uuid())
  name             String
  email            String    @unique
  phone            String?
  whatsappPhone    String?
  company          String?
  status           String    @default("lead")
  preferredChannel String    @default("email")
  leadScore        Int?
  source           String?
  tags             String?
  notes            String?
  lastContactedAt  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  deals              Deal[]
  activities         Activity[]
  tickets            Ticket[]
  emailMessages      EmailMessage[]
  whatsappMessages   WhatsAppMessage[]
  followUpExecutions FollowUpExecution[]
}

// ─── MARKETING ───────────────────────────────────────────

model Campaign {
  id             String    @id @default(uuid())
  name           String
  type           String    @default("email")
  status         String    @default("draft")
  subject        String?
  subjectB       String?
  content        String?
  audienceFilter String?
  scheduledFor   DateTime?
  sentAt         DateTime?
  sentCount      Int       @default(0)
  openCount      Int       @default(0)
  clickCount     Int       @default(0)
  openRate       Float     @default(0)
  clickRate      Float     @default(0)
  abTestEnabled  Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  emailMessages EmailMessage[]
  deals         Deal[]
}

// ─── SALES ───────────────────────────────────────────────

model Deal {
  id                String    @id @default(uuid())
  title             String
  value             Float     @default(0)
  stage             String    @default("lead")
  stageChangedAt    DateTime  @default(now())
  probability       Int       @default(0)
  expectedCloseDate DateTime?
  notes             String?
  source            String?   // e.g. "ai_classification", "manual", "import"
  lossReason        String?
  wonAt             DateTime?
  lostAt            DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  contactId  String
  contact    Contact    @relation(fields: [contactId], references: [id], onDelete: Cascade)
  activities Activity[]

  ownerId    String?
  owner      User?      @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  campaignId String?
  campaign   Campaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)
}

model SalesTarget {
  id          String   @id @default(uuid())
  period      String   @default("monthly") // monthly | quarterly | yearly
  startDate   DateTime
  endDate     DateTime
  targetAmount Float
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)
}

model Activity {
  id          String   @id @default(uuid())
  type        String
  description String
  createdAt   DateTime @default(now())

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  dealId    String?
  deal      Deal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)
}

// ─── SUPPORT ─────────────────────────────────────────────

model Ticket {
  id              String    @id @default(uuid())
  subject         String
  description     String
  status          String    @default("open")
  priority        String    @default("medium")
  category        String?
  aiSuggestion    String?
  satisfaction    Int?
  internalNotes   String?
  firstResponseAt DateTime?
  resolvedAt      DateTime?
  slaBreached     Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  contactId    String
  contact      Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assignedToId String?
  assignedTo   User?         @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  messages     ChatMessage[]
}

model KnowledgeBase {
  id          String   @id @default(uuid())
  question    String
  answer      String
  category    String?
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(uuid())
  role      String
  content   String
  createdAt DateTime @default(now())

  ticketId String?
  ticket   Ticket? @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

// ─── COMMUNICATIONS ─────────────────────────────────────

model EmailMessage {
  id          String    @id @default(uuid())
  direction   String    @default("outbound")
  fromAddr    String
  toAddr      String
  ccAddr      String?
  bccAddr     String?
  attachments String?   // JSON array of { name, size, type } — file metadata only
  subject     String
  body      String
  status    String    @default("draft")
  messageId String?
  inReplyTo String?
  sentAt    DateTime?
  openedAt  DateTime?
  createdAt DateTime  @default(now())

  // AI reply intelligence
  aiClassification String?  // positive | negative | question | neutral
  aiSummary        String?
  aiReplied        Boolean  @default(false)

  contactId    String
  contact      Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  userId       String?           // sender (the team member whose mailbox this came from / went out from)
  user         User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  templateId   String?
  template     MessageTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  followUpExecId String?
  followUpExec   FollowUpExecution? @relation(fields: [followUpExecId], references: [id], onDelete: SetNull)
  campaignId   String?
  campaign     Campaign?         @relation(fields: [campaignId], references: [id], onDelete: SetNull)
}

model WhatsAppMessage {
  id          String    @id @default(uuid())
  direction   String    @default("outbound")
  phone       String
  content     String
  mediaUrl    String?
  status      String    @default("sent")
  waMessageId String?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())

  contactId    String
  contact      Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  userId       String?           // sender — the user whose action triggered this message
  user         User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  templateId   String?
  template     MessageTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  followUpExecId String?
  followUpExec   FollowUpExecution? @relation(fields: [followUpExecId], references: [id], onDelete: SetNull)
}

// ─── TEMPLATES ───────────────────────────────────────────

model MessageTemplate {
  id        String   @id @default(uuid())
  name      String
  type      String   @default("email")
  subject   String?
  body      String
  variables String?
  category  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emailMessages    EmailMessage[]
  whatsappMessages WhatsAppMessage[]
  followUpSteps    FollowUpStep[]
}

// ─── FOLLOW-UP SEQUENCES ────────────────────────────────

model FollowUpSequence {
  id           String   @id @default(uuid())
  name         String
  description  String?
  isActive     Boolean  @default(true)
  triggerEvent String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  steps      FollowUpStep[]
  executions FollowUpExecution[]
}

model FollowUpStep {
  id           String   @id @default(uuid())
  stepOrder    Int
  channel      String   @default("email")
  subject      String?
  body         String?
  delayMinutes Int      @default(1440)
  condition    String?
  createdAt    DateTime @default(now())

  sequenceId String
  sequence   FollowUpSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  templateId String?
  template   MessageTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
}

model FollowUpExecution {
  id          String    @id @default(uuid())
  currentStep Int       @default(0)
  status      String    @default("active")
  nextRunAt   DateTime?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  sequenceId String
  sequence   FollowUpSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  contactId  String
  contact    Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)

  emailMessages    EmailMessage[]
  whatsappMessages WhatsAppMessage[]
}

// ─── ENTERPRISE ──────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // deal_won, new_reply, ticket_assigned, target_achieved, sla_breach, etc.
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── TASKS ───────────────────────────────────────────────

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  done        Boolean   @default(false)
  priority    String    @default("medium") // low, medium, high
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactId String?
  dealId    String?
  ticketId  String?
}

// ─── WORKFLOW AUTOMATION ─────────────────────────────────

model Workflow {
  id          String   @id @default(uuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  trigger     String   // contact_created, deal_stage_changed, lead_score_above, ticket_priority, etc.
  conditions  String?  // JSON string of condition object
  actions     String?  // JSON string of action array
  runCount    Int      @default(0)
  lastRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── API KEYS / WEBHOOKS / INTEGRATIONS ──────────────────

model ApiKey {
  id        String    @id @default(uuid())
  name      String
  key       String    @unique
  lastUsed  DateTime?
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  userId String?
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Webhook {
  id        String   @id @default(uuid())
  name      String
  url       String
  events    String   // comma-separated event names
  secret    String?
  isActive  Boolean  @default(true)
  lastFiredAt DateTime?
  failureCount Int   @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── LEAD ROUTING RULES ──────────────────────────────────

model LeadRoutingRule {
  id            String   @id @default(uuid())
  name          String
  // Match conditions — all optional, all ANDed
  sourcePattern String?  // case-insensitive substring match against contact.source
  domainPattern String?  // case-insensitive substring match against email domain
  tagPattern    String?  // case-insensitive substring match against tags
  // Action
  assignToUserId String?
  isActive       Boolean  @default(true)
  priority       Int      @default(100) // lower = higher priority
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── LEAD HANDOFF REQUESTS ───────────────────────────────

model LeadHandoffRequest {
  id          String   @id @default(uuid())
  contactId   String
  reason      String
  toUserId    String?  // requested target owner; null = "any admin, please reassign"
  status      String   @default("pending") // pending | approved | rejected
  reviewNote  String?
  createdAt   DateTime @default(now())
  reviewedAt  DateTime?

  requesterId String
  requester   User     @relation("HandoffRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  reviewerId  String?
  reviewer    User?    @relation("HandoffReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
}

// ─── SYSTEM SETTINGS (key-value config) ──────────────────

model SystemSetting {
  key       String   @id
  value     String   // JSON string for complex values, plain string for simple ones
  updatedAt DateTime @updatedAt
}

// ─── SAVED VIEWS ─────────────────────────────────────────

model SavedView {
  id        String   @id @default(uuid())
  name      String
  entity    String   // contact, deal, ticket, etc.
  filters   String   // JSON string of filter object
  createdAt DateTime @default(now())
}
